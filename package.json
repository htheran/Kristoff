{
    "name": "kristoff",
    "version": "1.0.0",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dist": "electron-builder"
    },
    "build": {
        "appId": "com.enterprise.credentialclient",
        "productName": "Kristoff",
        "win": {
            "target": "nsis",
            "certificateFile": null,
            "cscLink": null
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "include": "build/installer.nsh"
        }
    },
    "dependencies": {
        "axios": "^1.6.0"
    },
    "devDependencies": {
        "electron": "^30.0.0",
        "electron-builder": "^24.6.0"
    }
}